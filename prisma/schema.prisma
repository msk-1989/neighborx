// NeighborX — Hyperlocal Community & Commerce Super App
// Portable schema: runs on SQLite locally and PostgreSQL (Neon) on Vercel.
// Uses String for enum-like fields (no native PG enums) and no arrays —
// keeps the schema portable across both providers.
//
// The committed provider is "sqlite" for local dev. The Vercel build runs
// scripts/vercel-prebuild.sh which rewrites it to "postgresql" when
// DATABASE_PROVIDER=postgresql is set in the Vercel environment.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "sqlite"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  phone         String?
  avatar        String?
  bio           String?
  // role: RESIDENT | BUSINESS | SERVICE_PROVIDER | EMPLOYER | SOCIETY_ADMIN | GOV | SUPER_ADMIN
  role          String   @default("RESIDENT")
  // verification bitmask levels: 1=mobile,2=email,3=aadhaar,4=address,5=business
  verifyMobile  Boolean  @default(true)
  verifyEmail   Boolean  @default(false)
  verifyAadhaar Boolean  @default(false)
  verifyAddress Boolean  @default(false)
  verifyBusiness Boolean @default(false)
  rewardPoints  Int      @default(0)
  // Reputation tier: BRONZE | SILVER | GOLD | PLATINUM | LEGEND
  tier          String   @default("BRONZE")
  // Community Hero status
  heroLevel     Int      @default(0)
  // neighborhood context
  area          String   @default("Khair Nagar")
  city          String   @default("Udgir")
  district      String   @default("Latur")
  state         String   @default("Maharashtra")
  society       String   @default("Royal Residency")
  createdAt     DateTime @default(now())

  posts          Post[]
  comments       Comment[]
  reactions      Reaction[]
  listings       Listing[]
  businesses     Business[]
  bookings       ServiceBooking[]
  jobsPosted     Job[]        @relation("JobEmployer")
  applications   JobApplication[]
  emergencies    Emergency[]
  complaints     Complaint[]
  lostfound      LostFound[]
  events         Event[]      @relation("EventOrganizer")
  rsvps          RSVP[]
  chatMessages   ChatMessage[]
  notifications  Notification[]
  groupMemberships GroupMember[]
  groupsOwned   Group[]     @relation("GroupOwner")
  achievements   UserAchievement[]
  watchAlerts    WatchAlert[]
  // RBAC: a user can hold multiple roles (e.g. RESIDENT + BUSINESS_OWNER)
  roles          UserRole[]
  // admin-related
  societiesAdmin Society[]    @relation("SocietyAdmin")
  ticketsRequested SupportTicket[] @relation("TicketRequester")
  ticketsAssigned SupportTicket[] @relation("TicketAssignee")
  verificationsRequested VerificationRequest[] @relation("VerificationRequester")
  reportsFiled   AbuseReport[]  @relation("ReportReporter")
  reportsHandled AbuseReport[]  @relation("ReportHandler")
  payments       Payment[]
}

model Post {
  id          String   @id @default(cuid())
  // type: TEXT | IMAGE | VIDEO | POLL | EVENT | EMERGENCY
  type        String   @default("TEXT")
  content     String
  imageUrl    String?
  // JSON-ish poll data stored as String (question + options)
  pollData    String?
  scope       String   @default("SOCIETY") // SOCIETY | AREA | CITY
  tag         String?  // e.g. Recommendation, Update, Question
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  likes       Int      @default(0)
  comments    Comment[]
  reactions   Reaction[]
  createdAt   DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
}

model Reaction {
  id       String @id @default(cuid())
  postId   String
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id])
  // emoji: 👍 ❤️ 🙏 😂 🔥
  emoji    String @default("👍")
}

model Listing {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Int
  // category: ELECTRONICS | FURNITURE | VEHICLES | FASHION | BOOKS | APPLIANCES | OTHER
  category    String   @default("ELECTRONICS")
  condition   String   @default("Used") // New | Like New | Used | Refurbished
  imageUrl    String?
  location    String   @default("Khair Nagar, Udgir")
  boosted     Boolean  @default(false)
  status      String   @default("AVAILABLE") // AVAILABLE | SOLD | RESERVED
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id])
  createdAt   DateTime @default(now())
}

model Business {
  id          String   @id @default(cuid())
  name        String
  // category: GROCERY | RESTAURANT | CLINIC | PHARMACY | SALON | GYM | RETAIL | EDUCATION | OTHER
  category    String   @default("RETAIL")
  description String
  address     String
  phone       String
  rating      Float    @default(4.5)
  reviewCount Int      @default(0)
  imageUrl    String?
  verified    Boolean  @default(false)
  featured    Boolean  @default(false)
  offer       String?
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())
}

model Service {
  id          String   @id @default(cuid())
  // category: ELECTRICIAN | MAID | DRIVER | TUTOR | PLUMBER | CARPENTER | PAINTER | COOK | CLEANING | BEAUTY
  category    String   @default("PLUMBER")
  providerName String
  bio         String
  phone       String
  rating      Float    @default(4.5)
  jobsDone    Int      @default(0)
  hourlyRate  Int      @default(250)
  avatar      String?
  verified    Boolean  @default(false)
  available   Boolean  @default(true)
  bookings    ServiceBooking[]
}

model ServiceBooking {
  id         String   @id @default(cuid())
  serviceId  String
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  date       String
  slot       String
  note       String?
  status     String   @default("PENDING") // PENDING | CONFIRMED | COMPLETED | CANCELLED
  createdAt  DateTime @default(now())
}

model Job {
  id          String   @id @default(cuid())
  title       String
  company     String
  description String
  // type: FULL_TIME | PART_TIME | CONTRACT | INTERNSHIP | REMOTE
  jobType     String   @default("FULL_TIME")
  salary      String   @default("₹15,000 - ₹25,000")
  location    String   @default("Udgir")
  category    String   @default("GENERAL") // DELIVERY | RETAIL | SALES | TECH | ACCOUNTS | GENERAL
  openings    Int      @default(1)
  employerId  String
  employer    User     @relation("JobEmployer", fields: [employerId], references: [id])
  applications JobApplication[]
  createdAt   DateTime @default(now())
}

model JobApplication {
  id       String @id @default(cuid())
  jobId    String
  job      Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicantId String
  applicant User @relation(fields: [applicantId], references: [id])
  status   String @default("APPLIED") // APPLIED | REVIEWED | SHORTLISTED | REJECTED | HIRED
  cover    String?
  createdAt DateTime @default(now())
}

model Emergency {
  id          String   @id @default(cuid())
  // category: BLOOD | ACCIDENT | MEDICAL | MISSING_PERSON | FIRE | CRIME | WOMEN_SAFETY
  category    String   @default("MEDICAL")
  title       String
  description String
  location    String
  // severity: LOW | MEDIUM | HIGH | CRITICAL
  severity    String   @default("HIGH")
  status      String   @default("ACTIVE") // ACTIVE | RESOLVED
  reporterId  String
  reporter    User     @relation(fields: [reporterId], references: [id])
  responders  Int      @default(0)
  createdAt   DateTime @default(now())
}

model Complaint {
  id          String   @id @default(cuid())
  // category: ROAD | GARBAGE | WATER | ELECTRICITY | STREETLIGHT | DRAINAGE | OTHER
  category    String   @default("GARBAGE")
  title       String
  description String
  location    String
  imageUrl    String?
  // status: SUBMITTED | IN_PROGRESS | RESOLVED
  status      String   @default("SUBMITTED")
  // AI auto-classification confidence
  aiCategory  String?
  aiConfidence Float?
  reporterId  String
  reporter    User     @relation(fields: [reporterId], references: [id])
  upvotes     Int      @default(0)
  createdAt   DateTime @default(now())
}

model LostFound {
  id          String   @id @default(cuid())
  // type: LOST | FOUND
  type        String   @default("LOST")
  // category: PET | MOBILE | DOCUMENT | VEHICLE | KEYS | OTHER
  category    String   @default("OTHER")
  title       String
  description String
  imageUrl    String?
  location    String
  reward      Int      @default(0)
  status      String   @default("OPEN") // OPEN | REUNITED | CLOSED
  reporterId  String
  reporter    User     @relation(fields: [reporterId], references: [id])
  createdAt   DateTime @default(now())
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  // category: SOCIAL | SPORTS | CULTURAL | RELIGIOUS | EDUCATION | MEETING
  category    String   @default("SOCIAL")
  date        String
  time        String
  venue       String
  imageUrl    String?
  organizerId String
  organizer   User     @relation("EventOrganizer", fields: [organizerId], references: [id])
  rsvps       RSVP[]
  createdAt   DateTime @default(now())
}

model RSVP {
  id       String @id @default(cuid())
  eventId  String
  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  status   String @default("GOING") // GOING | INTERESTED | NOT_GOING
}

model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  text      String
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String
  // type: EMERGENCY | SOCIAL | MARKETPLACE | JOB | SYSTEM
  type      String   @default("SYSTEM")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ===== Phase 1 additions =====

// Community Groups — Pillar 1 (Community)
model Group {
  id          String   @id @default(cuid())
  name        String
  description String
  // category: HOBIES | SPORTS | RELIGIOUS | PROFESSIONAL | WOMEN | YOUTH | SENIORS | PARENTS | PETS | VOLUNTEER | OTHER
  category    String   @default("OTHER")
  icon        String?
  // privacy: PUBLIC | PRIVATE | SECRET
  privacy     String   @default("PUBLIC")
  scope       String   @default("SOCIETY") // SOCIETY | AREA | CITY
  area        String   @default("Khair Nagar")
  city        String   @default("Udgir")
  society     String   @default("Royal Residency")
  ownerId     String
  owner       User     @relation("GroupOwner", fields: [ownerId], references: [id])
  members     GroupMember[]
  memberCount Int      @default(1)
  createdAt   DateTime @default(now())
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  // role: OWNER | ADMIN | MEMBER
  role      String   @default("MEMBER")
  joinedAt  DateTime @default(now())

  @@unique([groupId, userId])
}

// Reputation & Gamification — Pillar 20 (Rewards & Gamification)
model Achievement {
  id          String   @id @default(cuid())
  // code is the stable identifier (e.g. FIRST_POST, HELPER, SOS_RESPONDER)
  code        String   @unique
  title       String
  description String
  icon        String
  // tier: BRONZE | SILVER | GOLD | PLATINUM | LEGEND
  tier        String   @default("BRONZE")
  points      Int      @default(10)
  earnedBy    UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  earnedAt      DateTime @default(now())

  @@unique([userId, achievementId])
}

// Neighborhood Watch — Pillar 3 (Safety)
model WatchAlert {
  id          String   @id @default(cuid())
  // type: SCAM | CRIME | SUSPICIOUS | SAFETY_TIP | MISSING_PERSON | MISSING_PET
  type        String   @default("SUSPICIOUS")
  title       String
  description String
  location    String
  // severity: LOW | MEDIUM | HIGH | CRITICAL
  severity    String   @default("MEDIUM")
  status      String   @default("ACTIVE") // ACTIVE | RESOLVED
  reporterId  String
  reporter    User     @relation(fields: [reporterId], references: [id])
  helpfulCount Int     @default(0)
  createdAt   DateTime @default(now())
}

// =====================================================================
// IAM / RBAC — Identity & Access Management
// =====================================================================
// Pillar: IAM (Role-Based Access Control). Every screen, button, API and
// action is controlled by Roles + Permissions. A user can hold multiple
// roles; each role grants a set of permissions.

// All possible roles (user-facing + 10-level admin hierarchy)
model Role {
  id          String   @id @default(cuid())
  // code: GUEST | RESIDENT | VERIFIED_RESIDENT | BUSINESS_OWNER |
  //       SERVICE_PROVIDER | EMPLOYER | PROPERTY_OWNER | VOLUNTEER |
  //       SOCIETY_ADMIN | AREA_MODERATOR | CITY_MODERATOR | BUSINESS_ADMIN |
  //       ORG_ADMIN | SUPPORT_ADMIN | OPERATIONS_ADMIN | REVENUE_ADMIN |
  //       COMPLIANCE_ADMIN | SUPER_ADMIN
  code        String   @unique
  name        String
  description String
  // level: 0=user roles, 1-10=admin hierarchy (Society Admin=1 ... Super Admin=10)
  level       Int      @default(0)
  // category: USER | ADMIN
  category    String   @default("USER")
  isSystem    Boolean  @default(true) // system roles cannot be deleted
  permissions RolePermission[]
  users       UserRole[]
  createdAt   DateTime @default(now())
}

model Permission {
  id          String   @id @default(cuid())
  // code: e.g. CREATE_POST, DELETE_POST, VERIFY_USER, MANAGE_CITY,
  //       APPROVE_BUSINESS, VIEW_REVENUE, MANAGE_USERS, etc.
  code        String   @unique
  name        String
  description String
  // module: which feature area this permission belongs to
  // COMMUNITY | MARKETPLACE | BUSINESS | SERVICE | JOB | PROPERTY |
  // SAFETY | SOCIETY | CIVIC | NEWS | REWARDS | AI | FINANCE | CMS |
  // SETTINGS | TRUST | IAM | SUPPORT | OPERATIONS | COMPLIANCE
  module      String   @default("COMMUNITY")
  // action: CREATE | READ | UPDATE | DELETE | APPROVE | VERIFY | MANAGE | VIEW
  action      String   @default("READ")
  roles       RolePermission[]
  createdAt   DateTime @default(now())
}

// Many-to-many: Role <-> Permission
model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
}

// Many-to-many: User <-> Role (a user can hold multiple roles)
model UserRole {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  // scope: for scoped roles like SOCIETY_ADMIN / AREA_MODERATOR, the scope
  // identifies the society/area/city the role applies to
  scope     String?
  grantedBy String?
  grantedAt DateTime @default(now())

  @@unique([userId, roleId, scope])
}

// =====================================================================
// Admin-ecosystem models
// =====================================================================

// Society — managed by Society Admin (Level 1)
model Society {
  id          String   @id @default(cuid())
  name        String
  address     String
  area        String   @default("Khair Nagar")
  city        String   @default("Udgir")
  district    String   @default("Latur")
  state       String   @default("Maharashtra")
  // total units / flats
  totalUnits  Int      @default(0)
  adminId     String?
  admin       User?    @relation("SocietyAdmin", fields: [adminId], references: [id])
  visitors    Visitor[]
  notices     SocietyNotice[]
  createdAt   DateTime @default(now())
}

model Visitor {
  id          String   @id @default(cuid())
  societyId   String
  society     Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  visitorName String
  visitorPhone String?
  hostName    String
  hostFlat    String
  // status: PENDING | APPROVED | CHECKED_IN | CHECKED_OUT | DENIED
  status      String   @default("PENDING")
  purpose     String?
  checkInTime DateTime?
  checkOutTime DateTime?
  createdAt   DateTime @default(now())
}

model SocietyNotice {
  id          String   @id @default(cuid())
  societyId   String
  society     Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  title       String
  body        String
  // type: ANNOUNCEMENT | MAINTENANCE | MEETING | EMERGENCY
  type        String   @default("ANNOUNCEMENT")
  createdAt   DateTime @default(now())
}

// Support tickets — handled by Support Admin (Level 6)
model SupportTicket {
  id          String   @id @default(cuid())
  // type: HELP | BUG | VERIFICATION | BILLING | ABUSE | OTHER
  type        String   @default("HELP")
  // status: OPEN | IN_PROGRESS | RESOLVED | CLOSED
  status      String   @default("OPEN")
  // priority: LOW | MEDIUM | HIGH | URGENT
  priority    String   @default("MEDIUM")
  subject     String
  description String
  requesterId String
  requester   User     @relation("TicketRequester", fields: [requesterId], references: [id])
  assigneeId  String?
  assignee    User?    @relation("TicketAssignee", fields: [assigneeId], references: [id])
  resolution  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Verification requests — handled by Operations Admin (Level 7)
model VerificationRequest {
  id          String   @id @default(cuid())
  // type: AADHAAR | ADDRESS | BUSINESS | SERVICE_PROVIDER | PROPERTY | FUNDRAISING
  type        String
  // status: PENDING | APPROVED | REJECTED
  status      String   @default("PENDING")
  requesterId String
  requester   User     @relation("VerificationRequester", fields: [requesterId], references: [id])
  // document URL / reference
  documentRef String?
  notes       String?
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
}

// Abuse reports — handled by Compliance Admin (Level 9)
model AbuseReport {
  id          String   @id @default(cuid())
  // targetType: POST | COMMENT | LISTING | BUSINESS | USER | MESSAGE
  targetType  String
  targetId    String
  reason      String
  description String?
  // status: PENDING | REVIEWING | ACTIONED | DISMISSED
  status      String   @default("PENDING")
  // action: NONE | WARNING | CONTENT_REMOVED | USER_SUSPENDED | USER_BANNED
  action      String   @default("NONE")
  reporterId  String
  reporter    User     @relation("ReportReporter", fields: [reporterId], references: [id])
  handlerId   String?
  handler     User?    @relation("ReportHandler", fields: [handlerId], references: [id])
  createdAt   DateTime @default(now())
  handledAt   DateTime?
}

// Payments — managed by Revenue Admin (Level 8)
model Payment {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  // type: SUBSCRIPTION | COMMISSION | REFUND | PAYOUT | LISTING_BOOST
  type        String
  amount      Float
  currency    String   @default("INR")
  // status: PENDING | SUCCESS | FAILED | REFUNDED
  status      String   @default("PENDING")
  // gateway: RAZORPAY | UPI | BANK_TRANSFER | WALLET
  gateway     String   @default("RAZORPAY")
  txnRef      String?
  invoiceNo   String?
  createdAt   DateTime @default(now())
}

// Subscriptions / plans
model Subscription {
  id          String   @id @default(cuid())
  // plan: FREE | BUSINESS_PRO | SERVICE_PRO | EMPLOYER_PRO | SOCIETY_PRO | ENTERPRISE
  plan        String   @default("FREE")
  price       Float    @default(0)
  billingCycle String  @default("MONTHLY") // MONTHLY | YEARLY
  features    String   // JSON string of feature list
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// CMS pages — managed via Super Admin CMS module
model CmsPage {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  content     String
  // type: PAGE | BLOG | FAQ
  type        String   @default("PAGE")
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Location master data — managed via Super Admin Settings module
model Location {
  id          String   @id @default(cuid())
  // level: COUNTRY | STATE | CITY | AREA
  level       String
  name        String
  parentId    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// Categories master data — managed via Super Admin Settings module
model Category {
  id          String   @id @default(cuid())
  // module: MARKETPLACE | BUSINESS | SERVICE | JOB | PROPERTY | EVENT
  module      String
  name        String
  icon        String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// OTP codes for passwordless login/register — expires in 10 minutes
model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  // purpose: LOGIN | REGISTER
  purpose   String   @default("LOGIN")
  consumed  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, createdAt])
}
