# Keep the Vercel build context lean — exclude everything that isn't needed
# to build & run the Next.js app.

# Local environment files — NEVER ship to Vercel. The local .env sets
# DATABASE_URL to an absolute dev path that doesn't exist on the Lambda runtime;
# src/lib/db.ts forces /tmp when process.env.VERCEL is set instead.
.env
.env.local
.env.*.local

# Local SQLite DB (Vercel uses /tmp at runtime instead)
db/
prisma/*.db
prisma/*.db-journal

# Separate sidecar services (socket.io chat runs only in the local sandbox)
mini-services/

# Reference / scaffold folders not part of the app
examples/
skills/
download/

# Build artifacts & deps (Vercel ignores these by default, but be explicit)
.next/
node_modules/

# Logs
*.log

# Local screenshots
*.png

# Vercel local state
.vercel/
