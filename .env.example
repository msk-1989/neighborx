# NeighborX — environment variable template.
# Copy to `.env` for local dev. For Vercel, set these in the Vercel dashboard
# (Project → Settings → Environment Variables). See DEPLOY.md for full guide.

# =============================================================================
# Database — PostgreSQL on Neon (used for BOTH local dev and Vercel)
# =============================================================================
# Neon gives you two connection strings:
#  - Pooled (PgBouncer, -pooler in hostname) → DATABASE_URL (app runtime)
#  - Direct (no -pooler)                     → DIRECT_DATABASE_URL (prisma CLI)
#
# Both are required. The Prisma CLI (db push / migrate) does NOT work through
# PgBouncer's transaction mode, so it needs the direct URL.

DATABASE_URL="postgresql://USER:PASS@ep-POOLER-ENDPOINT.REGION.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_DATABASE_URL="postgresql://USER:PASS@ep-DIRECT-ENDPOINT.REGION.aws.neon.tech/neondb?sslmode=require"

# =============================================================================
# Chat service (socket.io) — OPTIONAL
# =============================================================================
# Local sandbox uses the Caddy gateway with XTransformPort=3003. Leave unset.
# On Vercel, host the chat service separately (Render/Railway/Fly) and set this
# to the deployed URL so the frontend connects to it directly. If unset, chat
# falls back to 4s HTTP polling (still works, just not instant).
# NEXT_PUBLIC_CHAT_SERVICE_URL=https://neighborx-chat.onrender.com
