# NeighborX — environment variable template.
# Copy to `.env` for local dev. For Vercel, set these in the Vercel dashboard
# (Project → Settings → Environment Variables). See DEPLOY.md for full guide.

# =============================================================================
# Database
# =============================================================================
# Local dev uses SQLite (the committed prisma/schema.prisma has provider=sqlite).
# Vercel uses PostgreSQL (Neon) — the vercel-prebuild.sh script rewrites the
# provider to "postgresql" when DATABASE_PROVIDER=postgresql.

# --- LOCAL DEV (SQLite) ---
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:/home/z/my-project/db/custom.db
DIRECT_DATABASE_URL=file:/home/z/my-project/db/custom.db

# --- VERCEL (Neon Postgres) — set these in the Vercel dashboard, NOT here ---
# DATABASE_PROVIDER=postgresql
# DATABASE_URL=postgresql://USER:PASS@ep-POOLER-ENDPOINT.REGION.aws.neon.tech/neighborx?sslmode=require&pgbouncer=true&connect_timeout=15
# DIRECT_DATABASE_URL=postgresql://USER:PASS@ep-DIRECT-ENDPOINT.REGION.aws.neon.tech/neighborx?sslmode=require

# =============================================================================
# Chat service (socket.io) — OPTIONAL
# =============================================================================
# Local sandbox uses the Caddy gateway with XTransformPort=3003. Leave unset.
# On Vercel, host the chat service separately (Render/Railway/Fly) and set this
# to the deployed URL so the frontend connects to it directly.
# NEXT_PUBLIC_CHAT_SERVICE_URL=https://neighborx-chat.onrender.com

# =============================================================================
# Mini-service port (only used by mini-services/chat-service)
# =============================================================================
# Local sandbox default is 3003 (matches the gateway). External hosts set this
# automatically — do NOT hardcode on Render/Railway/Fly.
# PORT=3003
